# ─── API 연동 설정 (복사해서 .env.local 로 사용) ──────────────────────────────

# 실제 백엔드 API 를 사용하려면 "true". 비우거나 false 면 기존 mock 으로 동작.
VITE_USE_API=false

# API base 경로. 기본값 "/api/v1" — vite dev proxy 를 통해 백엔드로 전달됨.
# 보통 수정할 필요 없음.
# VITE_API_BASE_URL=/api/v1

# Vite dev proxy 가 /api 를 전달할 백엔드 주소 (개발 전용).
# 기본값 http://localhost:8000
# VITE_API_PROXY_TARGET=http://localhost:8000
